<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login - Student Management System</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <style>
    * { font-family: 'Inter', sans-serif; box-sizing: border-box; }
    body {
      display: flex;
      align-items: center;
      justify-content: center;
      height: 100vh;
      margin: 0;
      background: #F4F7FE;
    }
    .login-card {
      background: #fff;
      padding: 50px 40px;
      border-radius: 24px;
      box-shadow: 0 10px 40px rgba(0, 0, 0, 0.06);
      max-width: 420px;
      width: 100%;
    }
    .logo-box {
      width: 50px;
      height: 50px;
      background: linear-gradient(135deg, #FF9C00, #FFC048);
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 20px auto;
      color: #fff;
      font-weight: 700;
      font-size: 22px;
    }
    h3.login-title {
      text-align: center;
      font-weight: 700;
      color: #2B3674;
      margin-bottom: 4px;
    }
    p.login-subtext {
      text-align: center;
      color: #A3AED0;
      font-size: 14px;
      margin-bottom: 28px;
    }
    .form-label {
      color: #2B3674;
      font-weight: 500;
      font-size: 14px;
    }
    .form-control {
      background: #F8FAFC;
      border: 1px solid #E9EDF7;
      border-radius: 12px;
      padding: 12px 16px;
      margin-bottom: 18px;
    }
    .form-control:focus {
      border-color: #6366F1;
      box-shadow: 0 0 0 0.15rem rgba(99, 102, 241, 0.15);
      background: #fff;
    }
    .btn-signin {
      width: 100%;
      background: #6366F1;
      border: none;
      color: #fff;
      font-weight: 600;
      padding: 12px;
      border-radius: 12px;
      transition: background 0.2s ease;
    }
    .btn-signin:hover {
      background: #4F46E5;
      color: #fff;
    }
  </style>
</head>
<body>
  <div class="login-card">
    <div class="logo-box">S</div>
    <h3 class="login-title">Welcome Back</h3>
    <p class="login-subtext">Student Management System</p>

    <% if (typeof error !== 'undefined' && error) { %>
      <div class="alert alert-danger" role="alert">
        <%= error %>
      </div>
    <% } %>

    <form method="POST" action="/login">
      <label class="form-label">Email Address</label>
      <input type="text" class="form-control" name="email" placeholder="you@example.com" required>

      <label class="form-label">Password</label>
      <input type="password" class="form-control" name="password" placeholder="••••••••" required>

      <button type="submit" class="btn btn-signin">Sign In</button>
    </form>
  </div>
</body>
</html>
